  "item": [
    {
      "name": "🔐 Auth Service",
      "description": "Autenticação, refresh token e preferências de aprendizado (US-19, US-14).",
      "item": [
        {
          "name": "Cadastro de usuário",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.token) {",
                  "  pm.collectionVariables.set('token', resp.token);",
                  "  pm.collectionVariables.set('refresh_token', resp.refreshToken);",
                  "  console.log('Token salvo automaticamente.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Giullia Maria\",\n  \"email\": \"giulliamaria@ifsp.edu.br\",\n  \"senha\": \"123456\",\n  \"termosAceitos\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/registrar",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "registrar"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.token) {",
                  "  pm.collectionVariables.set('token', resp.token);",
                  "  pm.collectionVariables.set('refresh_token', resp.refreshToken);",
                  "  console.log('Token salvo. Expira em ' + resp.expiresIn + 's.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"giulliamaria@ifsp.edu.br\",\n  \"senha\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Renovar token (refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.token) {",
                  "  pm.collectionVariables.set('token', resp.token);",
                  "  pm.collectionVariables.set('refresh_token', resp.refreshToken);",
                  "  console.log('Token renovado com sucesso.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "response": []
        },
